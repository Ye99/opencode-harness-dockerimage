#!/usr/bin/env bash

set -euo pipefail

# Export env vars with defaults matching Dockerfile ENV declarations.
# Defaults are repeated here so the entrypoint also works outside Docker (e.g., in tests).
export OPENCODE_CONFIG="${OPENCODE_CONFIG:-/opt/opencode/opencode.json}"
export OPENCODE_CONFIG_DIR="${OPENCODE_CONFIG_DIR:-/opt/opencode}"
export OPENCODE_SERVER_PORT="${OPENCODE_SERVER_PORT:-4096}"
export OPENCODE_SERVER_HOST="${OPENCODE_SERVER_HOST:-0.0.0.0}"
export OCA_OAUTH_BIND_HOST="${OCA_OAUTH_BIND_HOST:-0.0.0.0}"
export OCA_OAUTH_CALLBACK_PORT="${OCA_OAUTH_CALLBACK_PORT:-48801}"
export WORKSPACE_DIR="${WORKSPACE_DIR:-/workspace}"
export BROWSER="${BROWSER:-/bin/true}"
AUTH_FILE="${XDG_DATA_HOME:-${HOME:-/root}/.local/share}/opencode/auth.json"

auth_signature() {
  if [[ -f "$AUTH_FILE" ]]; then
    cksum <"$AUTH_FILE"
    return
  fi
  printf 'missing\n'
}

# Map wildcard bind addresses to their loopback equivalents for local probing.
# When the server binds to all interfaces (0.0.0.0 or ::), we probe the
# loopback address instead, since we only need to verify the port is reachable locally.
probe_host() {
  case "$OPENCODE_SERVER_HOST" in
    0.0.0.0) printf '127.0.0.1\n' ;;
    ::) printf '::1\n' ;;
    *) printf '%s\n' "$OPENCODE_SERVER_HOST" ;;
  esac
}

terminate_child() {
  kill -- -"$child_pid" 2>/dev/null || true
  for _ in 1 2 3 4 5; do
    if ! kill -0 "$child_pid" 2>/dev/null; then
      return
    fi
    sleep 1
  done
  kill -9 -- -"$child_pid" 2>/dev/null || true
}

restart_requested=0
child_pid=''
last_exit_code=0

shutdown() {
  if [[ -n "$child_pid" ]]; then
    terminate_child
    wait "$child_pid" 2>/dev/null || true
  fi
}

trap 'shutdown; exit $last_exit_code' INT TERM

mkdir -p "$(dirname "$OPENCODE_CONFIG")"
cd "$WORKSPACE_DIR"

first_start=1
while true; do
  node "/opt/opencode/scripts/render-opencode-config.mjs" "/opt/opencode/opencode.base.json" "$OPENCODE_CONFIG"
  if [[ "$first_start" == 1 ]]; then
    bash "/opt/opencode/scripts/verify-runtime.sh" preflight
    first_start=0
  fi

  restart_requested=0
  previous_auth_signature="$(auth_signature)"
  setsid opencode web --hostname "$OPENCODE_SERVER_HOST" --port "$OPENCODE_SERVER_PORT" &
  child_pid="$!"

  while kill -0 "$child_pid" 2>/dev/null; do
    # Poll auth file every 2s; inotify would be more responsive but adds
    # complexity that is not justified for infrequent auth changes.
    sleep 2
    current_auth_signature="$(auth_signature)"
    if [[ "$current_auth_signature" != "$previous_auth_signature" ]]; then
      restart_requested=1
      printf 'auth-change-restart\n' >&2
      terminate_child
      break
    fi
  done

  if wait "$child_pid"; then
    last_exit_code=0
  else
    last_exit_code=$?
  fi
  child_pid=''

  if [[ "$restart_requested" == 1 ]]; then
    last_exit_code=0
    if ! node "/opt/opencode/scripts/port-drain-probe.mjs" "$(probe_host)" "$OPENCODE_SERVER_PORT"; then
      printf 'port-drain-timeout: port %s still occupied after 5s, proceeding with restart\n' "$OPENCODE_SERVER_PORT" >&2
    fi
    continue
  fi

  exit "$last_exit_code"
done
