#!/usr/bin/env bash

set -euo pipefail

export OPENCODE_CONFIG="${OPENCODE_CONFIG:-/opt/opencode/opencode.json}"
export OPENCODE_CONFIG_DIR="${OPENCODE_CONFIG_DIR:-/opt/opencode}"
export OPENCODE_SERVER_PORT="${OPENCODE_SERVER_PORT:-4096}"
export OPENCODE_SERVER_HOST="${OPENCODE_SERVER_HOST:-0.0.0.0}"
export OCA_OAUTH_BIND_HOST="${OCA_OAUTH_BIND_HOST:-0.0.0.0}"
export OCA_OAUTH_CALLBACK_PORT="${OCA_OAUTH_CALLBACK_PORT:-48801}"
export SUPERPOWERS_SKILLS_DIR="${SUPERPOWERS_SKILLS_DIR:-/opt/opencode/skills}"
export WORKSPACE_DIR="${WORKSPACE_DIR:-/workspace}"
export BROWSER="${BROWSER:-/bin/true}"

mkdir -p "$(dirname "$OPENCODE_CONFIG")"
node "/opt/opencode/scripts/render-opencode-config.mjs" "/opt/opencode/opencode.base.json" "$OPENCODE_CONFIG"
bash "/opt/opencode/scripts/verify-runtime.sh" preflight
cd "$WORKSPACE_DIR"
exec opencode web --hostname "$OPENCODE_SERVER_HOST" --port "$OPENCODE_SERVER_PORT"
