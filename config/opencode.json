{
  "$schema": "https://opencode.ai/config.json",
  "model": "oca/gpt-5.4",
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0"
  },
  "plugin": [
    "file:///opt/opencode/plugins/opencode-oca-auth",
    "file:///opt/opencode/plugins/superpowers.js"
  ],
  "provider": {
    "oca": {
      "models": {
        "gpt-5.4": {}
      }
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "*": "allow",
      "git push": "ask",
      "git push *": "ask",
      "git push *--force*": "deny",
      "git push *--mirror*": "deny",
      "git clean": "ask",
      "git reset --hard*": "ask",
      "git clean *": "ask",
      "rm": "ask",
      "rm *": "ask",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      "sudo": "deny",
      "sudo *": "deny"
    },
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "brave-search": {
      "type": "local",
      "command": [
        "mcp-server-brave-search"
      ],
      "enabled": false
    }
  }
}
