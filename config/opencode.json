{
  "$schema": "https://opencode.ai/config.json",
  "model": "oca/gpt-5.4",
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0"
  },
  "plugin": [
    "file:///opt/opencode/plugins/opencode-oca-auth",
    "file:///opt/opencode/plugins/superpowers.js"
  ],
  "provider": {
    "oca": {
      "models": {
        "gpt-5.4": {}
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "brave-search": {
      "type": "local",
      "command": [
        "mcp-server-brave-search"
      ],
      "enabled": false
    }
  }
}
